{% doc %}
  @prompt
    Create a Collection Cards Row section that displays collection images as boxes/cards with the collection label/title appearing below each card image (not overlaid on top). Each card should show the collection image filling the box, and the collection name (e.g., "Men's Fragrance", "Women's Fragrances", "Unisex", "Niche Fragrances", "Gift Sets", "New Arrivals") displayed as a clean label underneath the image box. The section should support multiple collection cards in a horizontal row, be responsive, and allow merchants to select which collections to display.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-cards-row-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-collection-cards-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-cards-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-collection-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    margin-top: {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: {{ block.settings.title_alignment }};
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-collection-card-count-{{ ai_gen_id }} {
    margin-top: 4px;
    font-size: {{ block.settings.count_size }}px;
    color: {{ block.settings.count_color }};
    text-align: {{ block.settings.title_alignment }};
  }

  @media screen and (max-width: 989px) {
    .ai-collection-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-collection-cards-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-collection-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }
  }
{% endstyle %}

<collection-cards-row-{{ ai_gen_id }} class="ai-collection-cards-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-cards-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-collection-cards-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-collection-cards-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}

        {% if collection != blank %}
          <a href="{{ collection.url }}" class="ai-collection-card-{{ ai_gen_id }}">
            <div class="ai-collection-card-image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.featured_image.alt | escape }}"
                  class="ai-collection-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: block.settings.image_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-collection-card-title-{{ ai_gen_id }}">
              {{ collection.title }}
            </div>
            {% if block.settings.show_product_count %}
              <div class="ai-collection-card-count-{{ ai_gen_id }}">
                {{ collection.products_count }}
                {% if collection.products_count == 1 %}
                  product
                {% else %}
                  products
                {% endif %}
              </div>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</collection-cards-row-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCardsRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('collection-cards-row-{{ ai_gen_id }}', CollectionCardsRow{{ ai_gen_id }});
  })();
</script>

