<section class="fragrance-finder premium-section">
  <div class="fragrance-finder__inner page-width">
    <div class="premium-section__header">
      {%- if section.settings.label != blank -%}
        <span class="premium-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="premium-section__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      <div class="premium-section__divider"></div>
      {%- if section.settings.subtitle != blank -%}
        <p class="premium-section__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="fragrance-finder__options premium-stagger">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="fragrance-finder__option premium-fade-in"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.icon != blank -%}
            <span class="fragrance-finder__option-icon">{{ block.settings.icon }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="fragrance-finder__option-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="fragrance-finder__option-text">{{ block.settings.description }}</p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fragrance Finder",
  "tag": "section",
  "class": "section-fragrance-finder",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Find Your Match"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Discover Your Perfect Scent"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Not sure where to start? Let us guide you to your ideal fragrance."
    }
  ],
  "blocks": [
    {
      "type": "option",
      "name": "Option",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "🌸"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "For Her"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Elegant and captivating feminine fragrances"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fragrance Finder",
      "blocks": [
        {
          "type": "option",
          "settings": {
            "icon": "🌸",
            "title": "For Her",
            "description": "Elegant and captivating feminine fragrances"
          }
        },
        {
          "type": "option",
          "settings": {
            "icon": "🌿",
            "title": "For Him",
            "description": "Bold and sophisticated masculine scents"
          }
        },
        {
          "type": "option",
          "settings": {
            "icon": "✨",
            "title": "Unisex",
            "description": "Versatile fragrances for everyone"
          }
        },
        {
          "type": "option",
          "settings": {
            "icon": "🎁",
            "title": "Gift Sets",
            "description": "Perfect presents for fragrance lovers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
