{%- style -%}
  .trust-badges-section {
    background-color: {{ section.settings.background_color }};
    padding: 48px 0 44px;
    text-align: center;
  }
  .trust-badges-section .section-heading {
    margin-bottom: 6px;
  }
  .trust-badges-section .section-heading h2 {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 2rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #fff;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    .trust-badges-section .section-heading h2 {
      font-size: 2.6rem;
    }
  }
  .trust-badges-section .section-subheading {
    color: rgba(255,255,255,0.7);
    font-size: 0.88rem;
    font-weight: 400;
    margin: 0 0 40px;
    letter-spacing: 0.03em;
  }
  .trust-badges-section .section-subheading strong {
    color: #fff;
    font-weight: 700;
  }
  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 16px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  @media screen and (min-width: 750px) {
    .trust-badges__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }
  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }
  @media screen and (min-width: 750px) {
    .trust-badge:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 10%;
      height: 80%;
      width: 1px;
      border-right: 1px dotted rgba(255,255,255,0.25);
    }
  }
  .trust-badge__icon {
    width: 56px;
    height: 56px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-badge__icon svg {
    width: 52px;
    height: 52px;
    stroke: #fff;
  }
  .trust-badge__icon .emoji-icon {
    font-size: 2.4rem;
  }
  .trust-badge__icon img {
    max-width: 52px;
    max-height: 52px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .trust-badge__title {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }
  .trust-badge__desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
    margin: 6px 0 0;
  }
{%- endstyle -%}

<section class="trust-badges-section">
  {%- if section.settings.heading != blank -%}
    <div class="section-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p class="section-subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div class="trust-badges__grid">
    {% for block in section.blocks %}
      <div class="trust-badge" {{ block.shopify_attributes }}>
        <div class="trust-badge__icon">
          {% if block.settings.icon_type == 'svg' %}
            {% case block.settings.svg_icon %}
              {% when 'shipping' %}
                <svg viewBox="0 0 64 64" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="20" width="36" height="22" rx="2"/><path d="M40 28h10l6 8v6h-16V28z"/><circle cx="16" cy="46" r="4"/><circle cx="48" cy="46" r="4"/><path d="M16 20V14h8"/><circle cx="20" cy="14" r="6"/><path d="M17 14l3 3 5-6"/></svg>
              {% when 'authentic' %}
                <svg viewBox="0 0 64 64" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="28" r="16"/><path d="M32 44v8"/><path d="M22 52h20"/><path d="M24 24l6 6 12-12"/><circle cx="32" cy="28" r="6" stroke-dasharray="2 3"/><path d="M16 28c0-8.8 7.2-16 16-16s16 7.2 16 16"/></svg>
              {% when 'guarantee' %}
                <svg viewBox="0 0 64 64" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M32 4l-8 8h-12v12l-8 8 8 8v12h12l8 8 8-8h12V40l8-8-8-8V12H40L32 4z"/><path d="M22 32l7 7 13-14"/></svg>
              {% when 'secure' %}
                <svg viewBox="0 0 64 64" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="24" width="36" height="28" rx="3"/><path d="M16 24V16a10 10 0 0120 0v8"/><rect x="44" y="28" width="14" height="20" rx="2"/><path d="M44 36h14"/><circle cx="26" cy="38" r="3"/><path d="M26 41v4"/><path d="M51 44l5 4"/></svg>
            {% endcase %}
          {% elsif block.settings.icon_type == 'image' and block.settings.icon_image != blank %}
            {{ block.settings.icon_image | image_url: width: 104 | image_tag: alt: block.settings.title }}
          {% else %}
            <span class="emoji-icon">{{ block.settings.icon_emoji }}</span>
          {% endif %}
        </div>
        <h3 class="trust-badge__title">{{ block.settings.title }}</h3>
        {%- if block.settings.description != blank -%}
          <p class="trust-badge__desc">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Perfect Scent at the Perfect Price"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Badge Title",
          "default": "100% Authentic"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "All products guaranteed authentic"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type",
          "options": [
            { "value": "emoji", "label": "Emoji" },
            { "value": "svg", "label": "Built-in SVG" },
            { "value": "image", "label": "Custom Image" }
          ],
          "default": "svg"
        },
        {
          "type": "select",
          "id": "svg_icon",
          "label": "SVG Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "authentic", "label": "Authentic/Shield" },
            { "value": "guarantee", "label": "Guarantee/Clock" },
            { "value": "secure", "label": "Secure/Lock" }
          ],
          "default": "authentic"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji Icon",
          "default": "✓"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "title": "FREE SHIPPING",
            "description": "On orders over €59",
            "icon_type": "svg",
            "svg_icon": "shipping"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "100% AUTHENTIC",
            "description": "Guaranteed genuine products",
            "icon_type": "svg",
            "svg_icon": "authentic"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "SATISFACTION GUARANTEED",
            "description": "30-day money back guarantee",
            "icon_type": "svg",
            "svg_icon": "guarantee"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "SAFE & SECURE",
            "description": "Encrypted checkout",
            "icon_type": "svg",
            "svg_icon": "secure"
          }
        }
      ]
    }
  ]
}
{% endschema %}
