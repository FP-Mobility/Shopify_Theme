{%- style -%}
  .featured-categories {
    padding: 60px 20px;
    background-color: #111111;
  }

  .featured-categories .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .section-title {
    text-align: center;
    font-size: 32px;
    margin-bottom: 40px;
    font-weight: 600;
    color: #ffffff;
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 30px;
    margin: 0 auto;
  }
  
  .category-card {
    text-align: center;
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 14px;
  }
  
  .category-card:hover {
    transform: translateY(-10px);
  }
  
  .category-image {
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 20px;
    height: 300px;
  }
  
  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .category-card:hover .category-image img {
    transform: scale(1.05);
  }
  
  .category-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .category-content h3 {
    font-size: 22px;
    margin-bottom: 10px;
    color: #ffffff;
  }

  .category-content p {
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    margin-bottom: 15px;
  }

  .featured-categories .button {
    display: inline-block;
    background-color: #c8a96b;
    color: #070707;
    padding: 12px 24px;
    margin-top: auto;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.3s ease;
    font-weight: 600;
    border: 1px solid #c8a96b;
    align-self: center;
  }
  
  .featured-categories .button:hover {
    background-color: transparent;
    border-color: #c8a96b;
    color: #c8a96b;
  }
  
  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .section-title {
      font-size: 24px;
    }
  }
  
  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }

    .category-image {
      height: 250px;
    }

    .featured-categories {
      padding: 40px 15px;
    }
  }
{%- endstyle -%}

<section class="featured-categories">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    
    <div class="categories-grid">
      {% for block in section.blocks %}
        <div class="category-card">
          {% if block.settings.image %}
            <div class="category-image">
              {{ block.settings.image | image_url: width: 500 | image_tag: alt: block.settings.title }}
            </div>
          {% else %}
            <div class="category-image" style="background-color: #e5e5e5; display: flex; align-items: center; justify-content: center;">
              <span style="color: #999;">No image</span>
            </div>
          {% endif %}
          
          <div class="category-content">
            <h3>{{ block.settings.title }}</h3>
            {% if block.settings.description %}
              <p>{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.collection %}
              <a href="{{ block.settings.collection.url }}" class="button">
                Shop {{ block.settings.title }}
              </a>
            {% else %}
              <button class="button" disabled style="opacity: 0.6; cursor: not-allowed;">
                Shop {{ block.settings.title }}
              </button>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Men's Fragrances"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Explore bold and sophisticated fragrances"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Men's Fragrances",
            "description": "Bold and sophisticated fragrances for men"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Women's Fragrances",
            "description": "Elegant and luxurious fragrances for women"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Unisex",
            "description": "Versatile fragrances for everyone"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Gift Sets",
            "description": "Perfect gifts for fragrance lovers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
