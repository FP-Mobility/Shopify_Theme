    { "type": "text", "id": "title", "label": "Heading", "default": "Where Luxury Meets Identity" },
    { "type": "richtext", "id": "text", "label": "Body Text", "default": "<p>At LumiScent, we believe fragrance is the invisible part of your personal style. Born from a passion for authentic luxury, we curate the world's finest perfumes from EU masters, Arabian oud artisans, and exclusive US importers.</p><p>Every bottle in our collection passes rigorous authenticity verification. We work directly with authorized distributors to guarantee you receive only genuine products at exceptional value.</p>" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#faf8f5" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "LEARN MORE" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
