{%- style -%}
  .brand-story {
    padding: 100px 0;
    background: {{ section.settings.background_color }};
    overflow: hidden;
    position: relative;
  }
  .brand-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }
  @media screen and (min-width: 990px) {
    .brand-story__grid {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }
  .brand-story__media {
    position: relative;
  }
  .brand-story__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .brand-story__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16,1,0.3,1);
  }
  .brand-story:hover .brand-story__image-wrapper img {
    transform: scale(1.04);
  }
  .brand-story__accent {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 120px;
    height: 120px;
    border: 1px solid var(--lux-gold, #C8A96B);
    opacity: 0.3;
    pointer-events: none;
  }
  .brand-story__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .brand-story__eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--lux-gold, #C8A96B);
    font-weight: 500;
  }
  .brand-story__title {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 2.4rem;
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: 0.03em;
    color: var(--lux-black, #0A0A0A);
    margin: 0;
  }
  @media screen and (min-width: 990px) {
    .brand-story__title { font-size: 3rem; }
  }
  .brand-story__divider {
    width: 48px;
    height: 1px;
    background: var(--lux-gold, #C8A96B);
  }
  .brand-story__text {
    font-size: 0.95rem;
    line-height: 1.8;
    color: #666;
  }
  .brand-story__text p { margin: 0 0 16px; }
  .brand-story__text p:last-child { margin-bottom: 0; }
  .brand-story__values {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 12px;
  }
  .brand-story__value {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .brand-story__value-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lux-gold, #C8A96B);
    font-size: 1.2rem;
  }
  .brand-story__value-text {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lux-black, #0A0A0A);
  }
  .brand-story__cta {
    display: inline-block;
    padding: 16px 44px;
    background: var(--lux-black, #0A0A0A);
    color: #fff;
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: all 0.3s;
    align-self: flex-start;
  }
  .brand-story__cta:hover {
    background: var(--lux-gold, #C8A96B);
    box-shadow: 0 4px 20px rgba(197,164,126,0.3);
  }
{%- endstyle -%}

<section class="brand-story">
  <div class="page-width">
    <div class="brand-story__grid">
      <div class="brand-story__media">
        <div class="brand-story__image-wrapper">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '400,600,900', sizes: '(min-width: 990px) 50vw, 100vw' }}
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#f5f0ea,#e8ddd0);"></div>
          {%- endif -%}
        </div>
        <div class="brand-story__accent"></div>
      </div>
      <div class="brand-story__content">
        <span class="brand-story__eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="brand-story__title">{{ section.settings.title }}</h2>
        <div class="brand-story__divider"></div>
        <div class="brand-story__text rte">{{ section.settings.text }}</div>
        <div class="brand-story__values">
          {%- for block in section.blocks -%}
            <div class="brand-story__value" {{ block.shopify_attributes }}>
              <span class="brand-story__value-icon">{{ block.settings.icon }}</span>
              <span class="brand-story__value-text">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="brand-story__cta">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
