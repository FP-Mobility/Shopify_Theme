{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

<div class="collection-hero-lux{% if section.settings.show_collection_image and collection.image %} collection-hero-lux--has-image{% endif %}">
  {%- if section.settings.show_collection_image and collection.image -%}
    <div class="collection-hero-lux__media">
      <img
        srcset="
          {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
          {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if collection.image.width >= 2000 -%}{{ collection.image | image_url: width: 2000 }} 2000w,{%- endif -%}
          {{ collection.image | image_url }} {{ collection.image.width }}w
        "
        src="{{ collection.image | image_url: width: 1500 }}"
        sizes="100vw"
        alt="{{ collection.image.alt | escape }}"
        width="{{ collection.image.width }}"
        height="{{ collection.image.height }}"
        loading="eager"
      >
    </div>
  {%- endif -%}
  <div class="collection-hero-lux__overlay"></div>
  <div class="collection-hero-lux__content page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <span class="collection-hero-lux__eyebrow">Collection</span>
    <h1 class="collection-hero-lux__title">
      {{- collection.title | escape -}}
    </h1>
    {%- if section.settings.show_collection_description and collection.description != blank -%}
      <div class="collection-hero-lux__desc rte">{{ collection.description }}</div>
    {%- endif -%}
    <div class="collection-hero-lux__count">
      {{ collection.products_count }} {{ collection.products_count | pluralize: 'Product', 'Products' }}
    </div>
  </div>
</div>

<style>
  .collection-hero-lux {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--lux-black, #070707);
    overflow: hidden;
    margin-bottom: 0;
  }
  .collection-hero-lux--has-image {
    min-height: 360px;
  }
  @media screen and (min-width: 750px) {
    .collection-hero-lux { min-height: 340px; }
    .collection-hero-lux--has-image { min-height: 440px; }
  }
  .collection-hero-lux__media {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .collection-hero-lux__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .collection-hero-lux__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to bottom,
      rgba(7, 7, 7, 0.6) 0%,
      rgba(7, 7, 7, 0.75) 100%
    );
  }
  .collection-hero-lux:not(.collection-hero-lux--has-image) .collection-hero-lux__overlay {
    background: transparent;
  }
  .collection-hero-lux__content {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 60px 24px;
    max-width: 720px;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    .collection-hero-lux__content { padding: 80px 40px; }
  }
  .collection-hero-lux__eyebrow {
    font-family: var(--font-body, sans-serif);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--lux-gold, #C8A96B);
    display: block;
    margin-bottom: 16px;
    font-weight: 500;
  }
  .collection-hero-lux__title {
    font-family: var(--font-display, serif) !important;
    font-size: 2.8rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--lux-white, #fff);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  @media screen and (min-width: 750px) {
    .collection-hero-lux__title { font-size: 3.6rem; }
  }
  .collection-hero-lux__desc {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto 16px;
    letter-spacing: 0.02em;
  }
  .collection-hero-lux__count {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
  }
</style>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
