{%- style -%}
  .olfactory-families {
    background: var(--lux-black, #070707);
    padding: 80px 0 60px;
    overflow: hidden;
  }
  .olfactory-families__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
    padding: 0 20px;
  }
  .olfactory-families__eyebrow {
    font-family: var(--font-body, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--lux-gold, #C8A96B);
    margin-bottom: 16px;
    display: block;
    font-weight: 500;
  }
  .olfactory-families__title {
    font-family: var(--font-display, serif);
    font-size: 2.4rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #ffffff;
    margin: 0 0 16px;
    line-height: 1.15;
  }
  @media screen and (min-width: 750px) {
    .olfactory-families__title { font-size: 3rem; }
  }
  .olfactory-families__subtitle {
    font-family: var(--font-body, sans-serif);
    font-size: 0.88rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    letter-spacing: 0.02em;
    margin: 0;
  }
  .olfactory-families__grid {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 20px 20px;
    scrollbar-width: none;
  }
  .olfactory-families__grid::-webkit-scrollbar { display: none; }
  @media screen and (min-width: 990px) {
    .olfactory-families__grid {
      display: grid;
      grid-template-columns: repeat({{ section.blocks.size | at_most: 6 }}, 1fr);
      overflow: visible;
      padding: 0 40px;
    }
  }
  .olfactory-card {
    flex: 0 0 200px;
    scroll-snap-align: start;
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  @media screen and (min-width: 990px) {
    .olfactory-card { flex: auto; }
  }
  .olfactory-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-luxury, ease);
  }
  .olfactory-card:hover .olfactory-card__image {
    transform: scale(1.08);
  }
  .olfactory-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.1) 100%);
    z-index: 1;
  }
  .olfactory-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
    z-index: 2;
  }
  .olfactory-card__icon {
    font-size: 1.6rem;
    margin-bottom: 8px;
    display: block;
  }
  .olfactory-card__name {
    font-family: var(--font-display, serif);
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: #ffffff;
    margin: 0 0 4px;
  }
  .olfactory-card__count {
    font-family: var(--font-body, sans-serif);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }
{%- endstyle -%}

<section class="olfactory-families">
  <div class="olfactory-families__header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="olfactory-families__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="olfactory-families__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="olfactory-families__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="olfactory-families__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="olfactory-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'olfactory-card__image', loading: 'lazy', sizes: '(min-width: 990px) 16vw, 200px' }}
          {%- else -%}
            <div class="olfactory-card__image" style="background: linear-gradient(135deg, #1a1a1a, #2a2a2a); width:100%; height:100%;"></div>
          {%- endif -%}
          <div class="olfactory-card__overlay"></div>
          <div class="olfactory-card__content">
            {%- if block.settings.icon != blank -%}
              <span class="olfactory-card__icon">{{ block.settings.icon }}</span>
            {%- endif -%}
            <h3 class="olfactory-card__name">{{ block.settings.name }}</h3>
            {%- if block.settings.count != blank -%}
              <span class="olfactory-card__count">{{ block.settings.count }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Olfactory Families",
  "tag": "section",
  "class": "section-olfactory-families",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Explore"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Olfactory Families"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Navigate our collection through the prism of olfactory families — each a distinct universe of emotion."
    }
  ],
  "blocks": [
    {
      "type": "family",
      "name": "Scent Family",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Family name",
          "default": "Woody"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon / emoji",
          "default": "🌲"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Subtitle text",
          "default": "42 Fragrances"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Olfactory Families",
      "blocks": [
        { "type": "family", "settings": { "name": "Woody", "icon": "🌲", "count": "Explore Collection" } },
        { "type": "family", "settings": { "name": "Floral", "icon": "🌸", "count": "Explore Collection" } },
        { "type": "family", "settings": { "name": "Oriental", "icon": "✨", "count": "Explore Collection" } },
        { "type": "family", "settings": { "name": "Fresh", "icon": "💧", "count": "Explore Collection" } },
        { "type": "family", "settings": { "name": "Citrus", "icon": "🍋", "count": "Explore Collection" } },
        { "type": "family", "settings": { "name": "Aromatic", "icon": "🌿", "count": "Explore Collection" } }
      ]
    }
  ]
}
{% endschema %}
