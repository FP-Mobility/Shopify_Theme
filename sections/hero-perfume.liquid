{%- style -%}
  .hero-perfume--{{ section.id }} .hero-perfume__overlay {
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section
  class="hero-perfume hero-perfume--{{ section.settings.height }}"
  data-parallax="{{ section.settings.enable_parallax }}"
>
  <div class="hero-perfume__media">
    {%- if section.settings.video_url != blank -%}
      <video
        autoplay
        muted
        loop
        playsinline
        poster="{%- if section.settings.image != blank -%}{{ section.settings.image | image_url: width: 1920 }}{%- endif -%}"
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          alt: section.settings.image.alt | default: section.settings.title
      }}
    {%- else -%}
      <div style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); width: 100%; height: 100%; min-height: inherit;"></div>
    {%- endif -%}
  </div>

  <div class="hero-perfume__overlay"></div>

  <div class="hero-perfume__content hero-perfume__content--{{ section.settings.content_position }}">
    <div class="hero-perfume__content-inner">
      {%- if section.settings.subtitle != blank -%}
        <p class="hero-perfume__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="hero-perfume__title">{{ section.settings.title }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero-perfume__description">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="hero-perfume__buttons">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            {% if section.settings.button_link_1 != blank %}href="{{ section.settings.button_link_1 }}"{% endif %}
            class="button button--primary"
          >
            {{ section.settings.button_label_1 | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a
            {% if section.settings.button_link_2 != blank %}href="{{ section.settings.button_link_2 }}"{% endif %}
            class="button button--secondary"
          >
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Hero",
  "tag": "section",
  "class": "section-hero-perfume",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Optional. Upload video to Shopify Files and paste URL here."
    },
    {
      "type": "select",
      "id": "height",
      "options": [
        { "value": "small", "label": "Small (420px)" },
        { "value": "medium", "label": "Medium (580px)" },
        { "value": "large", "label": "Large (90vh)" },
        { "value": "full", "label": "Full Screen (100vh)" }
      ],
      "default": "large",
      "label": "Height"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable Parallax Effect",
      "default": true
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 30,
      "unit": "%",
      "label": "Overlay Opacity"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Content Position"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover Luxury"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Your Signature Scent Awaits"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our curated collection of the world's finest fragrances, crafted for those who appreciate the art of perfumery."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 Label",
      "default": "Shop Women"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 Label",
      "default": "Shop Men"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "Premium Hero"
    }
  ]
}
{% endschema %}
