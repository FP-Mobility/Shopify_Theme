<section class="instagram-feed">
  <div class="instagram-feed__header">
    <div class="premium-section__header">
      {%- if section.settings.label != blank -%}
        <span class="premium-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="premium-section__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      <div class="premium-section__divider"></div>
    </div>
  </div>

  <div class="instagram-feed__grid">
    {%- for block in section.blocks -%}
      <div class="instagram-feed__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 750px) 16.66vw, 33.33vw',
              widths: '200, 300, 400, 600',
              alt: block.settings.image.alt | default: 'Instagram post'
          }}
        {%- else -%}
          <div style="background: var(--premium-light-gray); width: 100%; height: 100%;"></div>
        {%- endif -%}
        <a
          href="{{ block.settings.link | default: section.settings.instagram_url | default: '#' }}"
          class="instagram-feed__item-overlay"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="View on Instagram"
        >
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.instagram_handle != blank -%}
    <div class="instagram-feed__handle">
      <a href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" rel="noopener noreferrer">
        @{{ section.settings.instagram_handle }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section-instagram-feed",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Follow Us"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop Our Instagram"
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram Handle",
      "default": "lumiscent"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram Profile URL"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
