{%- style -%}
  .fragrance-quiz {
    padding: 80px 0;
    background: linear-gradient(135deg, #0A0A0A 0%, #1a1a2e 100%);
    overflow: hidden;
    position: relative;
  }
  .fragrance-quiz::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at 30% 50%, rgba(197,164,126,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .fragrance-quiz__inner {
    position: relative;
    z-index: 1;
  }
  .fragrance-quiz__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .fragrance-quiz__eyebrow {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #C8A96B;
    margin-bottom: 16px;
    font-weight: 500;
  }
  .fragrance-quiz__title {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 2.6rem;
    font-weight: 300;
    color: #fff;
    margin: 0 0 12px;
    letter-spacing: 0.04em;
  }
  @media screen and (min-width: 750px) {
    .fragrance-quiz__title { font-size: 3.2rem; }
  }
  .fragrance-quiz__subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 0.95rem;
    margin: 0;
    max-width: 500px;
    margin-left: auto; margin-right: auto;
  }

  /* Steps */
  .quiz-step { display: none; }
  .quiz-step.active { display: block; animation: quizFadeIn 0.5s ease; }
  @keyframes quizFadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  .quiz-step__question {
    text-align: center;
    font-family: var(--font-display, serif);
    font-size: 1.6rem;
    font-weight: 300;
    color: #fff;
    margin-bottom: 36px;
  }
  .quiz-step__options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 700px;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    .quiz-step__options { grid-template-columns: repeat(3, 1fr); }
  }
  .quiz-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 24px 16px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.03);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }
  .quiz-option:hover {
    border-color: #C8A96B;
    background: rgba(197,164,126,0.08);
    transform: translateY(-4px);
  }
  .quiz-option.selected {
    border-color: #C8A96B;
    background: rgba(197,164,126,0.15);
    box-shadow: 0 0 20px rgba(197,164,126,0.15);
  }
  .quiz-option__icon {
    font-size: 2rem;
    line-height: 1;
  }
  .quiz-option__label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
  }
  .quiz-option__desc {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
  }

  /* Progress */
  .quiz-progress {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }
  .quiz-progress__dot {
    width: 32px;
    height: 3px;
    background: rgba(255,255,255,0.15);
    transition: background 0.3s;
  }
  .quiz-progress__dot.active { background: #C8A96B; }
  .quiz-progress__dot.done { background: rgba(197,164,126,0.5); }

  /* Navigation */
  .quiz-nav {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 36px;
  }
  .quiz-nav__btn {
    padding: 14px 40px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    font-family: var(--font-body, sans-serif);
  }
  .quiz-nav__btn--back {
    background: transparent;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
  }
  .quiz-nav__btn--back:hover { border-color: rgba(255,255,255,0.4); color: #fff; }
  .quiz-nav__btn--next {
    background: #C8A96B;
    color: #fff;
  }
  .quiz-nav__btn--next:hover { background: #b8936d; box-shadow: 0 4px 20px rgba(197,164,126,0.3); }
  .quiz-nav__btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* Results */
  .quiz-results { text-align: center; }
  .quiz-results__heading {
    font-family: var(--font-display, serif);
    font-size: 2rem;
    color: #fff;
    font-weight: 300;
    margin-bottom: 12px;
  }
  .quiz-results__match {
    font-size: 0.82rem;
    color: #C8A96B;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 32px;
  }
  .quiz-results__cta {
    display: inline-block;
    padding: 16px 48px;
    background: #C8A96B;
    color: #fff;
    text-decoration: none;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .quiz-results__cta:hover { background: #b8936d; box-shadow: 0 4px 20px rgba(197,164,126,0.3); }
  .quiz-results__restart {
    display: block;
    margin-top: 20px;
    color: rgba(255,255,255,0.4);
    font-size: 0.78rem;
    cursor: pointer;
    background: none;
    border: none;
    text-decoration: underline;
  }
{%- endstyle -%}

