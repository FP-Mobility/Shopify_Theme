<section class="newsletter-perfume">
  <div class="newsletter-perfume__inner">
    {%- if section.settings.label != blank -%}
      <span class="newsletter-perfume__label">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="newsletter-perfume__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="newsletter-perfume__divider"></div>

    {%- if section.settings.text != blank -%}
      <p class="newsletter-perfume__text">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'NewsletterPerfume' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="newsletter-perfume__success">
          {{ 'newsletter.success' | t }}
        </p>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="newsletter-perfume__error">
          {{ form.errors.translated_fields['email'] | capitalize }}
          {{ form.errors.messages['email'] }}
        </p>
      {%- endif -%}

      <div class="newsletter-perfume__form">
        <input
          type="email"
          name="contact[email]"
          class="newsletter-perfume__input"
          placeholder="{{ section.settings.placeholder }}"
          required
          autocomplete="email"
          aria-label="{{ section.settings.placeholder }}"
          {% if form.errors %}
            autofocus
            aria-invalid="true"
            aria-describedby="Newsletter-error"
          {% endif %}
        >
        <button type="submit" class="newsletter-perfume__button">
          {{ section.settings.button_label }}
        </button>
      </div>
      <label class="newsletter-perfume__consent">
        <input type="checkbox" name="contact[note]" value="Newsletter marketing consent" required>
        <span>
          Ich möchte den LumiScent Newsletter mit Angeboten und Neuheiten erhalten und akzeptiere die
          <a href="/pages/datenschutzerklarung-schutz-ihrer-personenbezogenen-daten">Datenschutzerklärung</a>.
          Eine Abmeldung ist jederzeit möglich.
        </span>
      </label>
    {%- endform -%}

    {%- if section.settings.privacy_text != blank -%}
      <p class="newsletter-perfume__privacy">{{ section.settings.privacy_text }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  .newsletter-perfume__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    max-width: 760px;
    margin: 1rem auto 0;
    color: rgba(var(--color-foreground), 0.72);
    font-size: 1.2rem;
    line-height: 1.5;
    text-align: left;
  }

  .newsletter-perfume__consent input {
    margin-top: 0.25rem;
    flex: 0 0 auto;
  }

  .newsletter-perfume__consent a {
    color: currentColor;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }
</style>

{% schema %}
{
  "name": "Premium Newsletter",
  "tag": "section",
  "class": "section-newsletter-perfume",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "LUMISCENT NEWSLETTER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Neuheiten von LumiScent erhalten"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Erhalte Updates zu neuen Düften, Aktionen und Dufttipps direkt per E-Mail."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "E-Mail-Adresse eingeben"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Text",
      "default": "Mit der Anmeldung akzeptierst du unsere Datenschutzerklärung. Abmeldung jederzeit möglich."
    }
  ],
  "presets": [
    {
      "name": "Premium Newsletter"
    }
  ]
}
{% endschema %}
