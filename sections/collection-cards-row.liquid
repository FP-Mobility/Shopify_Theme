{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="collection-cards-row section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="collection-cards-row__header">
        <h2 class="collection-cards-row__title h1">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="collection-cards-row__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="collection-cards-row__scroll-wrapper">
    <div class="collection-cards-row__scroll page-width">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="collection-cards-row__card" {{ block.shopify_attributes }}>
          <div class="collection-cards-row__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  class: 'collection-cards-row__image',
                  widths: '300, 400, 600',
                  sizes: '(min-width: 990px) 280px, (min-width: 750px) 220px, 180px'
              }}
            {%- else -%}
              <div class="collection-cards-row__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
            <div class="collection-cards-row__overlay"></div>
            <div class="collection-cards-row__content">
              <h3 class="collection-cards-row__name">{{ block.settings.title | default: 'Collection' }}</h3>
              {%- if block.settings.product_count != blank -%}
                <span class="collection-cards-row__count">{{ block.settings.product_count }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Cards Row",
  "tag": "section",
  "class": "section section-collection-cards-row",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "product_count",
          "label": "Product count text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Cards Row",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Men's Fragrances" }},
        { "type": "collection_card", "settings": { "title": "Women's Fragrances" }},
        { "type": "collection_card", "settings": { "title": "Unisex" }},
        { "type": "collection_card", "settings": { "title": "Niche Fragrances" }},
        { "type": "collection_card", "settings": { "title": "Gift Sets" }},
        { "type": "collection_card", "settings": { "title": "New Arrivals" }}
      ]
    }
  ]
}
{% endschema %}