<style>
  .brand-showcase {
    background: var(--lux-black, #070707);
    padding: 48px 0;
    overflow: hidden;
    border-top: 1px solid rgba(200,169,107,0.06);
    border-bottom: 1px solid rgba(200,169,107,0.06);
  }
  .brand-showcase__label {
    text-align: center;
    font-family: var(--font-body, sans-serif);
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 32px;
    display: block;
  }
  .brand-marquee {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
  }
  .brand-marquee__track {
    display: inline-flex;
    animation: brand-scroll {{ section.settings.scroll_speed | default: 30 }}s linear infinite;
    will-change: transform;
  }
  .brand-marquee:hover .brand-marquee__track {
    animation-play-state: paused;
  }
  .brand-marquee__item {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .brand-marquee__name {
    font-family: var(--font-display, serif);
    font-size: 1.6rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.3s ease;
    text-transform: uppercase;
  }
  @media screen and (min-width: 750px) {
    .brand-marquee__name { font-size: 2rem; }
  }
  .brand-marquee__name:hover {
    color: var(--lux-gold, #C8A96B);
  }
  .brand-marquee__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(200,169,107,0.3);
    margin: 0 32px;
    flex-shrink: 0;
  }
  .brand-showcase__cta {
    text-align: center;
    margin-top: 36px;
  }
  .brand-showcase__cta a {
    font-family: var(--font-body, sans-serif);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--lux-gold, #C8A96B);
    text-decoration: none;
    border-bottom: 1px solid rgba(200,169,107,0.3);
    padding-bottom: 2px;
    transition: all 0.3s ease;
  }
  .brand-showcase__cta a:hover {
    border-color: var(--lux-gold, #C8A96B);
  }
  @keyframes brand-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="brand-showcase">
  {%- if section.settings.subtitle != blank -%}
    <span class="brand-showcase__label">{{ section.settings.subtitle }}</span>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="brand-marquee">
      <div class="brand-marquee__track">
        {%- for i in (1..2) -%}
          {%- for block in section.blocks -%}
            <span class="brand-marquee__item" {{ block.shopify_attributes }}>
              {%- if block.settings.brand_collection -%}
                <a href="{{ block.settings.brand_collection.url }}" class="brand-marquee__name">{{ block.settings.brand_name }}</a>
              {%- else -%}
                <a href="{{ routes.all_products_collection_url }}?filter.v.option.brand={{ block.settings.brand_name | url_encode }}" class="brand-marquee__name">{{ block.settings.brand_name }}</a>
              {%- endif -%}
            </span>
            <span class="brand-marquee__dot" aria-hidden="true"></span>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_all_link -%}
    <div class="brand-showcase__cta">
      <a href="/pages/brands">View All Brands</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Brand Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Top Perfume & Cologne Brands"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Shop from the world's finest fragrance brands"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Show 'View All Brands' Button",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed (seconds)",
      "min": 15,
      "max": 60,
      "step": 5,
      "default": 30
    },
    {
      "type": "page",
      "id": "all_brands_page",
      "label": "All Brands Page"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo"
        },
        {
          "type": "collection",
          "id": "brand_collection",
          "label": "Brand Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Showcase",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 1"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 2"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 3"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
