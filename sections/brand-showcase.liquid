<section class="brand-showcase">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    {% if section.settings.subtitle %}
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
    <div class="gold-sep"></div>

    <div class="brands-grid">
      {% for block in section.blocks %}
        {% if block.settings.brand_collection %}
          <a href="{{ block.settings.brand_collection.url }}" class="brand-item" {{ block.shopify_attributes }}>
        {% else %}
          <div class="brand-item" {{ block.shopify_attributes }}>
        {% endif %}
          {% if block.settings.brand_logo %}
            <div class="brand-logo">
              {{ block.settings.brand_logo | image_url: width: 200 | image_tag: alt: block.settings.brand_name }}
            </div>
          {% endif %}
          <p class="brand-name">{{ block.settings.brand_name }}</p>
        {% if block.settings.brand_collection %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_all_link %}
      <div class="view-all">
        {% if section.settings.all_brands_page %}
          <a href="{{ section.settings.all_brands_page.url }}" class="button">
            View All Brands
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Brand Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Top Perfume & Cologne Brands"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Shop from the world's finest fragrance brands"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Show 'View All Brands' Button",
      "default": true
    },
    {
      "type": "page",
      "id": "all_brands_page",
      "label": "All Brands Page"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo"
        },
        {
          "type": "collection",
          "id": "brand_collection",
          "label": "Brand Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Showcase",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 1"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 2"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 3"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
