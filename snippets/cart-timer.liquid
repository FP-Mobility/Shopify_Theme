{%- comment -%}
  Cart Reservation Timer
  Displays a countdown timer for cart items to create urgency
  Usage: {% render 'cart-timer' %}
  Place inside each cart-item row
{%- endcomment -%}

<div class="cart-timer" data-cart-timer>
  <svg class="cart-timer__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
    <circle cx="8" cy="8" r="7"/><path d="M8 4v4l3 2"/>
  </svg>
  <span class="cart-timer__text" data-cart-timer-text>Reserved for <strong data-cart-timer-countdown>15:00</strong></span>
</div>

<style>
  .cart-timer {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    padding: 6px 10px;
    background: #fff8f0;
    border: 1px solid #f0e6d8;
    border-radius: 4px;
    font-size: 0.72rem;
    color: #8b6914;
    letter-spacing: 0.02em;
  }
  .cart-timer__icon {
    flex-shrink: 0;
    color: var(--lux-gold, #C8A96B);
  }
  .cart-timer__text strong {
    font-weight: 700;
    color: #a0522d;
    font-variant-numeric: tabular-nums;
  }
  .cart-timer--urgent {
    background: #fff0f0;
    border-color: #f5d0d0;
    color: #b22222;
  }
  .cart-timer--urgent .cart-timer__icon {
    color: #b22222;
  }
  .cart-timer--urgent .cart-timer__text strong {
    color: #b22222;
  }
  .cart-timer--expired .cart-timer__text strong {
    color: #999;
  }
</style>


